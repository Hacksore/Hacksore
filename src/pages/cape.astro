---
import { MinecraftSkin } from "../components/minecraft-skin";
import Layout from "../layouts/layout.astro";

const META_INFO = {
  title: "Sean Boult | Minecon Cape",
  description: "🫵 YOU CANT HAVE MY CAPE",
  ogImage: "/img/cape-og.png",
};
---

<Layout title={META_INFO.title} description={META_INFO.description} ogImage={META_INFO.ogImage}>
  <div class="prose prose-invert">
    <h1>Minecon 2011 Cape</h1>
    <p class="not-prose page-lede max-w-2xl">
      Minecon 2011 cape. Not selling or trading. Viewer below beats asking on Discord.
    </p>
    <div class="flex item-center justify-center w-full">
      <MinecraftSkin client:load width={600} height={600} />
    </div>
  </div>
</Layout>
