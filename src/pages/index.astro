---
import { DEVTO_TOKEN } from "astro:env/server";
import { About } from "../components/about";
import { BidwatchCallout } from "../components/bidwatch-callout";
import type { Post } from "../components/post-card";
import { PostCard, resolvePostCoverImage } from "../components/post-card";
import { Social } from "../components/social";
import Layout from "../layouts/layout.astro";

const DISPLAY_COUNT = 6;
const FETCH_COUNT = 50;

// TODO: error handle
const allArticles = (await fetch(
  `https://dev.to/api/articles/me/published?per_page=${FETCH_COUNT}`,
  {
    headers: {
      "api-key": DEVTO_TOKEN,
    },
  },
).then((res) => res.json())) as Post[];
const byPublishedDesc = (a: Post, b: Post) =>
  new Date(b.published_at).getTime() - new Date(a.published_at).getTime();

const sortedArticles = [...allArticles].sort(byPublishedDesc);
const latestArticles = sortedArticles
  .filter((post) => resolvePostCoverImage(post))
  .slice(0, DISPLAY_COUNT);
const debugPosts = Astro.url.searchParams.get("debugPosts") === "1";
const debugRows = sortedArticles.slice(0, 12).map((post) => {
  const resolvedCoverImage = resolvePostCoverImage(post);
  return {
    id: post.id,
    title: post.title,
    published_at: post.published_at,
    renderable: Boolean(resolvedCoverImage),
    cover_image: post.cover_image ?? null,
    social_image: post.social_image ?? null,
    resolved_cover_image: resolvedCoverImage ?? null,
  };
});

if (debugPosts) {
  console.log(
    "[devto-debug] Homepage post diagnostics",
    JSON.stringify(
      {
        totalFetched: allArticles.length,
        renderableCount: sortedArticles.filter((post) => resolvePostCoverImage(post)).length,
        displayingCount: latestArticles.length,
        rows: debugRows,
      },
      null,
      2,
    ),
  );
}

Astro.response.headers.set("Cache-Control", "public, s-maxage=300, stale-while-revalidate=600");
---

<Layout
  mainClass="max-w-6xl"
  description="Developer stuff @ AWS. Building, shipping, and hacking on all kinds of software for over 10 years."
>
  <section class="flex justify-center"><About client:load /></section>

  <section><Social client:load /></section>

  <section class="mt-10 mb-16 md:mb-20">
    <BidwatchCallout />
    {
      debugPosts && (
        <details class="mb-6 rounded-lg border border-amber-500/60 bg-amber-500/10 p-4 text-sm text-amber-100">
          <summary class="cursor-pointer font-semibold">DEV posts debug (debugPosts=1)</summary>
          <pre class="mt-3 overflow-x-auto whitespace-pre-wrap break-words text-xs">
            {
              JSON.stringify(
                {
                  totalFetched: allArticles.length,
                  renderableCount: sortedArticles.filter((post) => resolvePostCoverImage(post)).length,
                  displayingCount: latestArticles.length,
                  rows: debugRows,
                },
                null,
                2,
              )
            }
          </pre>
        </details>
      )
    }
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 px-4">
      {latestArticles.map((post) => <PostCard post={post} />)}
    </div>
    <div class="text-center mt-12">
      <a
        href="https://dev.to/hacksore"
        class="inline-flex items-center gap-2 px-6 py-3 bg-(--color-primary) text-white rounded-lg font-medium hover:bg-blue-600 transition-colors"
        target="_blank"
        rel="noopener noreferrer"
      >
        View all articles on Dev.to
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <title>Opens in new tab</title>
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
          ></path>
        </svg>
      </a>
    </div>
  </section>
</Layout>
